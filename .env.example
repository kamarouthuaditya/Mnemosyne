# Copy to .env and fill in after creating your Supabase project.
# Settings -> API in the Supabase dashboard.

# --- Push script (scripts/push.py) : write access, bypasses RLS ---
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET. never commit. never ship to the browser.

# --- Skill : where the local markdown store lives (optional override) ---
# Defaults to <repo>/career-memory if unset.
WORKLOG_HOME=C:\Users\Aditya Kamarouthu\Personal\projects\work-memory\career-memory

# --- Next.js app (app/.env.local) : read-only, safe for the browser ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
